st.markdown("---")

# ---------------- SAMPLE STATISTICS ---------------- #

st.subheader("📈 System Statistics")

chart_data = pd.DataFrame({
    "Month": ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
    "Patients": [120, 180, 220, 260, 300, 380]
})

st.line_chart(
    chart_data.set_index("Month")
)

