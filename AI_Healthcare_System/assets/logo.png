<li>📋 Reports</li>
</ul>
</div>
""",
unsafe_allow_html=True)

st.markdown("---")

# ---------------- FEATURES ---------------- #

st.subheader("✨ Key Features")

c1, c2, c3 = st.columns(3)

with c1:

    st.info("""
### 🤖 Artificial Intelligence

✔ Disease Prediction

