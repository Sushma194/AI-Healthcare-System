import streamlit as st
import pandas as pd
import os

# ---------------- PAGE CONFIG ---------------- #

st.set_page_config(
    page_title="AI Healthcare System",
    page_icon="🏥",
    layout="wide"
)

# ---------------- LOAD CSS ---------------- #

def load_css():
    css_file = "assets/styles.css"

    if os.path.exists(css_file):
        with open(css_file) as f:
            st.markdown(
                f"<style>{f.read()}</style>",
                unsafe_allow_html=True
            )

load_css()

# ---------------- SIDEBAR ---------------- #

st.sidebar.image(
    "assets/logo.png",
    width=180
)

st.sidebar.title("🏥 Healthcare AI")

st.sidebar.success(
    "AI-Powered Healthcare Platform"
)

# ---------------- HEADER ---------------- #

st.title(
    "🏥 AI-Powered Healthcare Prediction & Resource Management System"
)

st.markdown(
    """
### Welcome to the Healthcare Intelligence Platform

This platform helps hospitals improve patient care through Artificial Intelligence, Machine Learning, and Resource Optimization.
"""
)

st.markdown("---")

# ---------------- KPI DASHBOARD ---------------- #

st.subheader("📊 Hospital Overview")

col1, col2, col3, col4 = st.columns(4)

with col1:
    st.metric(
        "👨‍⚕️ Patients",
        "1,245",
        "+12%"
    )

with col2:
    st.metric(
        "🩺 Doctors",
        "85",
        "+5%"
    )

with col3:
    st.metric(
        "🛏 Beds Occupied",
        "320",
        "+8%"
    )

with col4:
    st.metric(
        "📅 Appointments",
        "540",
        "+20%"
    )

st.markdown("---")

